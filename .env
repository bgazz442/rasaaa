# React App Environment Variables
# These variables must start with REACT_APP_ to be accessible in React

# HOST Configuration for ngrok access
HOST=0.0.0.0
DANGEROUSLY_DISABLE_HOST_CHECK=true

# API Base URL - Use relative path for production/ngrok compatibility
# Leave empty to use relative paths (works for both localhost and ngrok)
REACT_APP_API_URL=

# Public URL for share links (auto-detected if empty)
# REACT_APP_PUBLIC_URL=https://jacalyn-archiepiscopal-marquita.ngrok-free.dev

# Alternatively, if you have a specific backend URL (including ngrok):
# REACT_APP_API_URL=https://your-ngrok-url.ngrok.io

# Application Environment
REACT_APP_ENV=development

# Google Gemini API Key
# Dapatkan API key dari: https://aistudio.google.com/app/apikey
# TARO API KEY DI .env.local (lebih aman, ga ke-upload ke GitHub)
# Contoh: GEMINI_API_KEY=AIzaSy...

# For production builds, set these before building:
# REACT_APP_API_URL=/api (if using proxy)
# REACT_APP_ENV=production
